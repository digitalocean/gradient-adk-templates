# DigitalOcean Gradient AI Configuration
DIGITALOCEAN_INFERENCE_KEY=your_digitalocean_inference_key_here

# Snowflake Connection Configuration
# Get your account identifier from the Snowflake console (bottom-left corner)
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=DATA_ENGINEERING_WH
SNOWFLAKE_DATABASE=DATA_ENGINEERING_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=DATA_ENGINEERING_ROLE
